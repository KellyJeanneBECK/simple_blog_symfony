{% extends 'base.html.twig' %}

{% block title %}Simple Blog{% endblock %}

{% block body %}
<main>
    <h2>Home</h2>
    <section>
        {% for article in articleList %}
            <article>
                <h3>{{ article.title }}</h3>
                <h4>{{ article.user.pseudo }}</h4>
                <p>{{ article.category.name }}</p>
                <p>{{ article.createdAt|date }}</p>
                <p>{{ article.content|slice(0, 60) }}...</p>
                <a href="">Read</a>
            </article>
        {% endfor %}
    </section>
</main>
{% endblock %}
